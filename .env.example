DATABASE_URL="postgresql://postgres:postgres@localhost:5432/social_media_app?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Optional overrides for `npm run db:seed`
# SEED_ADMIN_NAME="Humberto"
# SEED_ADMIN_EMAIL="hto.montenegro@gmail.com"
# SEED_ADMIN_PASSWORD=""
# Public token for the login-page wall+carousel embed (must match seeded widget)
# SEED_LOGIN_WIDGET_TOKEN="seed-login-wall-carousel"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Media: local uploads (default) or S3
STORAGE_MODE="local"
UPLOAD_DIR="public/uploads"
# S3 (optional)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
CDN_BASE_URL="http://localhost:3000"
